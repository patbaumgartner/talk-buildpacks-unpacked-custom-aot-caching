#!/usr/bin/env bash
# AOT Cache Buildpack - Build Phase
set -euo pipefail

log() { echo "  $*" >&2; }
log_error() { echo "  ERROR: $*" >&2; }

echo
echo "Patbaumgartner AOT Cache Buildpack 0.1.0"
echo "  https://github.com/patbaumgartner/talk-buildpacks-unpacked-custom-aot-caching"
echo

LAYER_NAME="aot-cache"
LAYER_DIR="${CNB_LAYERS_DIR}/${LAYER_NAME}"
LAYER_TOML="${LAYER_DIR}.toml"
AOT_FILE="${LAYER_DIR}/app.aot"
APP_HASH_FILE="${LAYER_DIR}/app.sha"

# Create layer directory
mkdir -p "${LAYER_DIR}"

# Compute a fingerprint for the app
APP_DIR="${CNB_APP_DIR:-/workspace}"

CURRENT_HASH="$(find "${APP_DIR}" -maxdepth 1 -name '*.jar' -print0 \
  | sort -z \
  | xargs -0 sha256sum \
  | sha256sum \
  | cut -d' ' -f1)"

# If we have a restored cache and the hash matches, reuse it
if [[ -f "${APP_HASH_FILE}" && -f "${AOT_FILE}" ]]; then
  PREV_HASH="$(cat "${APP_HASH_FILE}")"
  if [[ "${PREV_HASH}" == "${CURRENT_HASH}" ]]; then
    AOT_SIZE=$(du -h "${AOT_FILE}" 2>/dev/null | cut -f1 || echo "unknown")
    log "AOT Cache: Reusing cached layer (${AOT_SIZE})"
    # ensure metadata/env are correct and exit early
    cat > "${LAYER_TOML}" <<EOL
[types]
launch = true
build = true
cache = true

[metadata]
app_sha = "${CURRENT_HASH}"
EOL

    mkdir -p "${LAYER_DIR}/env.launch"
    echo " " > "${LAYER_DIR}/env.launch/JAVA_TOOL_OPTIONS.delim"
    echo " -XX:AOTCache=${AOT_FILE}" > "${LAYER_DIR}/env.launch/JAVA_TOOL_OPTIONS.append"
    exit 0
  fi
fi

# Validate Java availability
JAVA_BIN="${JAVA_HOME:-}/bin/java"
if [[ ! -x "${JAVA_BIN}" ]]; then
  if command -v java >/dev/null 2>&1; then
    JAVA_BIN="$(command -v java)"
  else
    log_error "Java not found (JAVA_HOME or PATH). Ensure Java buildpack runs first."
    exit 1
  fi
fi

# Check Java version
JAVA_VERSION=$("${JAVA_BIN}" -version 2>&1 | head -n 1 | awk -F '"' '{print $2}')
JAVA_MAJOR=$(echo "${JAVA_VERSION}" | cut -d'.' -f1)

if [[ "${JAVA_MAJOR}" -lt 25 ]]; then
  log "WARNING: Java 25+ required for AOT caching (found ${JAVA_VERSION})"
  log "Skipping AOT cache generation"
  exit 0
fi

log "Using Java version ${JAVA_VERSION}"

# Generate a new AOT cache
log "AOT Cache: Contributing to layer"

# -XX:AOTCacheOutput is a single command which is combining the previous 2 step process before Java 25
CMD=(
  "${JAVA_BIN}" -cp "."
  -XX:AOTCacheOutput="${AOT_FILE}"
  -Dspring.context.exit=onRefresh
  org.springframework.boot.loader.launch.JarLauncher
)

if [[ "${BP_AOT_CACHING_DEBUG:-false}" == "true" ]]; then
  CMD=(
    "${JAVA_BIN}" -cp "."
    -Xlog:aot=info
    -Xlog:class+path=info
    -XX:AOTCacheOutput="${AOT_FILE}"
    -Dspring.context.exit=onRefresh
    org.springframework.boot.loader.launch.JarLauncher
  )
fi

# IMPORTANT: no 'exec' here, we want the script to continue after Java exits
if ! "${CMD[@]}"; then
  log_error "AOT cache generation failed"
  exit 1
fi

echo "${CURRENT_HASH}" > "${APP_HASH_FILE}"

cat > "${LAYER_TOML}" <<EOL
[types]
launch = true
build = true
cache = true

[metadata]
app_sha = "${CURRENT_HASH}"
EOL

# Verify AOT file was created
if [[ ! -f "${AOT_FILE}" ]]; then
  log_error "AOT cache file not created"
  log_error "Application may not support AOT compilation"
  exit 1
fi

AOT_SIZE=$(du -h "${AOT_FILE}" | cut -f1)
log
log "Generated AOT cache (${AOT_SIZE})"
log "Writing env.launch/JAVA_TOOL_OPTIONS.append"

# Append the JVM flag at launch using layer env
mkdir -p "${LAYER_DIR}/env.launch"
echo " " > "${LAYER_DIR}/env.launch/JAVA_TOOL_OPTIONS.delim"
echo " -XX:AOTCache=${AOT_FILE}" > "${LAYER_DIR}/env.launch/JAVA_TOOL_OPTIONS.append"

# All done
log "AOT Cache: Layer contribution complete"

exit 0
